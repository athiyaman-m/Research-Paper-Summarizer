# ── Option 1: Groq API (recommended – fast, free, no tunnel needed) ─────────
GROQ_API_KEY = ""           # Get free key at https://console.groq.com
GROQ_MODEL = "llama-3.3-70b-versatile"  # or "llama-3.2-3b-preview" for faster/cheaper

# ── Option 2: Local Ollama via tunnel ────────────────────────────────────────
# OLLAMA_BASE_URL = "https://your-tunnel.trycloudflare.com"
# OLLAMA_MODEL = "llama3.2:3b"
# OLLAMA_TIMEOUT_SEC = "120"
# OLLAMA_NUM_CTX = "2048"
# OLLAMA_MAX_INPUT_CHARS = "12000"
# OLLAMA_MAX_RETRIES = "3"

# ── Option 3: Local GGUF file (for local dev only) ───────────────────────────
# SUMMARIX_MODEL_PATH = "models/llama-3.2-1b-instruct.Q4_K_M.gguf"

# App settings
SUMMARIX_REQUIRE_LLM = "true"
