# LLaMA-only configuration
SUMMARIX_REQUIRE_LLM = "true"

# Optional: set backend explicitly to 'ollama' or 'local'.
# If omitted, app auto-selects ollama when OLLAMA_BASE_URL is set, else local.
SUMMARIX_LLM_PROVIDER = "ollama"

# LLaMA via Ollama API (recommended for deployed app)
# Example: https://your-tunnel-subdomain.trycloudflare.com
OLLAMA_BASE_URL = ""
OLLAMA_MODEL = "llama3.2:3b"
OLLAMA_TIMEOUT_SEC = "120"

# LLaMA via local GGUF (used when OLLAMA_BASE_URL is empty)
SUMMARIX_MODEL_PATH = "models/llama-3.2-1b-instruct.Q4_K_M.gguf"
