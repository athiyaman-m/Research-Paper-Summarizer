# Choose ONE provider: openai | ollama | local
SUMMARIX_LLM_PROVIDER = "openai"

# Enforce no-fallback behavior
SUMMARIX_REQUIRE_LLM = "true"

# Option A: OpenAI (cloud)
OPENAI_API_KEY = "your_openai_api_key"
OPENAI_MODEL = "gpt-4o-mini"

# Option B: Ollama endpoint (local/free via tunnel)
# Example: https://your-tunnel-subdomain.trycloudflare.com
OLLAMA_BASE_URL = ""
OLLAMA_MODEL = "llama3.2:3b-instruct"
OLLAMA_TIMEOUT_SEC = "120"

# Option C: Local GGUF model path (local machine run)
SUMMARIX_MODEL_PATH = "models/llama-3.2-1b-instruct.Q4_K_M.gguf"
