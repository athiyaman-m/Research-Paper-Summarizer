# Choose one provider backend: local | ollama | gemini | groq | openai
SUMMARIX_LLM_PROVIDER = "gemini"

# Enforce real LLM only (no fallback)
SUMMARIX_REQUIRE_LLM = "true"

# ---- LLaMA via local GGUF (app runs on same machine) ----
SUMMARIX_MODEL_PATH = "models/llama-3.2-1b-instruct.Q4_K_M.gguf"

# ---- LLaMA via Ollama API (local/free via tunnel) ----
# Example: https://your-tunnel-subdomain.trycloudflare.com
OLLAMA_BASE_URL = ""
OLLAMA_MODEL = "llama3.2:3b-instruct"
OLLAMA_TIMEOUT_SEC = "120"

# ---- Gemini API ----
GEMINI_API_KEY = ""
GEMINI_MODEL = "gemini-2.0-flash"

# ---- Groq API ----
GROQ_API_KEY = ""
GROQ_MODEL = "llama-3.1-8b-instant"

# ---- OpenAI API (optional) ----
OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-4o-mini"
